# SignalFlow Environment Variables

# Service URLs
QUANTFLOW_URL=ws://localhost:8000
NARRATIVEFLOW_URL=ws://localhost:8001

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signalflow

# API Configuration
API_HOST=0.0.0.0
API_PORT=8002
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_INTERVAL=5
WS_MAX_RECONNECT_INTERVAL=60

# Fusion Engine Configuration
CONVICTION_UPDATE_INTERVAL=1
HISTORY_RETENTION_HOURS=24
MAX_ALERTS=1000